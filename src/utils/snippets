onClick={() => userAuthType === 'phone' ? setShowPhoneModal(true) : setShowEmailModal(true)}
{showPhoneModal && (
						<PhoneInput onClose={() => setShowPhoneModal(false) } onAction={() => checkAndProcessVoter(voter)} />
					)}

					{showEmailModal && (
						<CollectEmailModal
							isOpen={showEmailModal}
							onClose={() => setShowEmailModal(false)}
							onSubmit={() => checkAndProcessVoter(voter)}
						/>
)}